---
import Layout from './Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import AdBanner from '../components/AdBanner.astro'
import CTABox from '../components/CTABox.astro'
import NewsletterSignup from '../components/NewsletterSignup.astro'
import RelatedPosts from '../components/RelatedPosts.astro'

interface Props {
  title: string
  description: string
  pubDate: Date
  updatedDate?: Date
  heroImage?: string
  category: string
  author: string
  readTime?: string
  tags?: string[]
  section?: 'blog' | 'reports'
  gated?: boolean
  youtubeId?: string
  slug: string
}

const { title, description, pubDate, updatedDate, heroImage, category, author, readTime, tags, section = 'blog', gated = false, youtubeId, slug } = Astro.props
const sectionLabel = section === 'reports' ? 'Reports' : 'Blog'
const sectionHref = section === 'reports' ? '/reports' : '/blog'

const formattedDate = new Intl.DateTimeFormat('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(pubDate)

const formattedUpdatedDate = updatedDate
  ? new Intl.DateTimeFormat('en-AU', { year: 'numeric', month: 'long', day: 'numeric' }).format(updatedDate)
  : null

// Article structured data — references the sitewide Person/Organization by @id.
const siteUrl = (Astro.site?.href || 'https://marcoweb.org/').replace(/\/$/, '')
const articleUrl = new URL(Astro.url.pathname, Astro.site).href
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', '@id': `${siteUrl}/#marco`, name: author, url: `${siteUrl}/about/` },
  publisher: {
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: 'MarcoWeb',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/logo.png` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  ...(heroImage ? { image: new URL(heroImage, Astro.site).href } : {}),
  ...(tags && tags.length ? { keywords: tags.join(', ') } : {}),
}
---

<Layout title={`${title} | MarcoWeb`} description={description} image={heroImage}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <Header />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-6">
      <a href="/" class="hover:text-brand-blue transition-colors">Home</a>
      <span class="mx-2">›</span>
      <a href={sectionHref} class="hover:text-brand-blue transition-colors">{sectionLabel}</a>
      <span class="mx-2">›</span>
      <span class="text-gray-600">{title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold uppercase tracking-widest text-brand-blue bg-blue-50 px-3 py-1 rounded-full">
          {category}
        </span>
        {readTime && <span class="text-xs text-gray-400">{readTime}</span>}
      </div>

      <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 leading-tight mb-4">
        {title}
      </h1>

      <p class="text-lg text-gray-500 leading-relaxed mb-6">
        {description}
      </p>

      <!-- Author bar -->
      <div class="flex items-center gap-4 text-sm text-gray-400 border-t border-gray-100 pt-4">
        <div class="flex items-center gap-2">
          <img
            src="/images/marco.jpg"
            alt={author}
            class="w-10 h-10 rounded-full border-2 border-brand-blue object-cover"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div class="w-10 h-10 rounded-full bg-brand-blue items-center justify-center text-white font-bold text-sm hidden">M</div>
          <div>
            <p class="font-semibold text-gray-800 text-sm">{author}</p>
            <p class="text-xs text-gray-400">Cybersecurity Analyst</p>
          </div>
        </div>
        <span class="text-gray-200">|</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {formattedUpdatedDate && formattedUpdatedDate !== formattedDate && (
          <>
            <span>·</span>
            <span>Updated {formattedUpdatedDate}</span>
          </>
        )}
      </div>
    </header>

    <!-- Video (if present) — otherwise hero image -->
    {youtubeId ? (
      <div class="mb-8 rounded-2xl overflow-hidden shadow-md aspect-video bg-black">
        <iframe
          class="w-full h-full"
          src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
          title={title}
          loading="lazy"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    ) : heroImage && (
      <div class="mb-8 rounded-2xl overflow-hidden shadow-md">
        <img
          src={heroImage}
          alt={title}
          class="w-full h-auto max-h-96 object-cover"
        />
      </div>
    )}

    <!-- Top ad -->
    <AdBanner slot="leaderboard" />

    <!-- Article content -->
    <div class="relative">
      <div id="post-content" data-gated={gated ? 'true' : 'false'} class="prose prose-gray prose-lg max-w-none
        prose-headings:font-bold prose-headings:text-gray-900
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b prose-h2:border-gray-100 prose-h2:pb-2
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-brand-navy
        prose-p:text-gray-700 prose-p:leading-relaxed
        prose-strong:text-gray-900
        prose-a:text-brand-blue prose-a:no-underline hover:prose-a:underline
        prose-ul:my-4 prose-li:my-1
        prose-table:text-sm prose-th:bg-brand-navy prose-th:text-white prose-th:font-semibold prose-th:py-3 prose-th:px-4 prose-td:py-2 prose-td:px-4
        prose-blockquote:border-brand-blue prose-blockquote:text-gray-600
        prose-code:text-brand-blue prose-code:bg-blue-50 prose-code:px-1 prose-code:rounded
        prose-hr:border-gray-200">
        <slot />
      </div>

      {gated && (
        <div id="report-gate" style="display:none">
          <div class="h-32 -mt-32 bg-gradient-to-t from-white to-transparent pointer-events-none relative z-10" aria-hidden="true"></div>
          <div class="relative z-20 border-2 border-brand-blue rounded-2xl p-8 bg-white shadow-xl text-center mt-0">
            <p class="text-xs font-bold uppercase tracking-widest text-brand-blue mb-2">Free report</p>
            <h2 class="text-2xl font-extrabold text-gray-900 mb-2">Subscribe to read the full report</h2>
            <p class="text-gray-500 text-sm mb-1">Join the MarcoWeb newsletter — IT audit and cybersecurity analysis, no spam.</p>
            <p class="text-gray-500 text-sm mb-6">You'll also unlock the <strong class="text-gray-800">free ITGC Audit Workbook</strong> (38 controls, Excel template).</p>
            <form id="gate-form" novalidate class="max-w-sm mx-auto">
              <input
                type="email"
                id="gate-email"
                placeholder="you@company.com"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm mb-3 focus:outline-none focus:border-brand-blue"
              />
              <button
                id="gate-btn"
                type="submit"
                class="w-full bg-brand-blue hover:bg-brand-light text-white font-bold py-3 rounded-lg transition-colors text-sm"
              >
                Subscribe & Continue Reading →
              </button>
              <p id="gate-error" style="display:none" class="text-red-500 text-xs mt-2"></p>
            </form>
            <p class="text-xs text-gray-400 mt-4">Free · No spam · Unsubscribe any time.</p>
          </div>
          <div id="gate-success" style="display:none" class="mt-4 p-4 bg-green-50 border border-green-200 rounded-xl flex items-center justify-between gap-4">
            <p class="font-semibold text-green-800 text-sm">You're subscribed — enjoy the full report.</p>
            <a
              href="https://lgyblltyytfmoovigdrj.supabase.co/storage/v1/object/public/templates/ITGC_Audit_Workbook.xlsx"
              target="_blank"
              class="shrink-0 bg-brand-blue text-white text-xs font-bold px-4 py-2 rounded-lg hover:bg-brand-light transition-colors"
            >
              Download Workbook →
            </a>
          </div>
        </div>
      )}
    </div>

    <!-- Mid-article ad -->
    <AdBanner slot="rectangle" />

    <!-- Tags -->
    {tags && tags.length > 0 && (
      <div class="mt-10 pt-6 border-t border-gray-100">
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="text-xs text-gray-500 bg-gray-100 hover:bg-gray-200 px-3 py-1 rounded-full transition-colors">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Author card -->
    <div class="mt-10 pt-8 border-t border-gray-100 flex items-start gap-5">
      <img
        src="/images/marco.jpg"
        alt={author}
        class="w-16 h-16 rounded-full border-2 border-brand-blue object-cover shrink-0"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <div class="w-16 h-16 rounded-full bg-brand-blue items-center justify-center text-white font-bold text-xl shrink-0 hidden">M</div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-blue mb-1">Written by</p>
        <p class="font-bold text-gray-900 text-lg">{author}</p>
        <p class="text-gray-500 text-sm leading-relaxed mt-1">
          Cybersecurity analyst and IT governance professional. Author of digital reports on threat intelligence, critical infrastructure security, and IT audit frameworks.
        </p>
      </div>
    </div>

    <!-- Related posts -->
    <RelatedPosts currentSlug={slug} tags={tags} section={section} />

    <!-- Newsletter CTA -->
    <div class="mt-12">
      <NewsletterSignup />
    </div>

    <!-- Full CTA -->
    <CTABox variant="full" />
  </main>

  <Footer />
</Layout>

{gated && (
  <script is:inline>
  (function () {
    var el = document.getElementById('post-content')
    if (!el || el.dataset.gated !== 'true') return

    if (localStorage.getItem('mw_sub') === '1') return

    var kids = Array.from(el.children)
    var SHOW = 6
    kids.slice(SHOW).forEach(function (k) { k.style.display = 'none' })

    var gate = document.getElementById('report-gate')
    if (gate) gate.style.display = 'block'

    var form = document.getElementById('gate-form')
    if (!form) return

    form.addEventListener('submit', async function (e) {
      e.preventDefault()
      var email = document.getElementById('gate-email').value.trim()
      var btn = document.getElementById('gate-btn')
      var err = document.getElementById('gate-error')

      if (!email || !email.includes('@')) {
        err.textContent = 'Please enter a valid email.'
        err.style.display = 'block'
        return
      }

      btn.disabled = true
      btn.textContent = 'Subscribing…'
      err.style.display = 'none'

      try {
        var res = await fetch('/.netlify/functions/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email })
        })
        if (res.ok) {
          localStorage.setItem('mw_sub', '1')
          kids.forEach(function (k) { k.style.display = '' })
          gate.style.display = 'none'
          var success = document.getElementById('gate-success')
          if (success) {
            success.style.display = 'flex'
            window.scrollBy({ top: 200, behavior: 'smooth' })
          }
        } else {
          throw new Error()
        }
      } catch {
        btn.disabled = false
        btn.textContent = 'Subscribe & Continue Reading →'
        err.textContent = 'Something went wrong. Please try again.'
        err.style.display = 'block'
      }
    })
  })()
  </script>
)}
