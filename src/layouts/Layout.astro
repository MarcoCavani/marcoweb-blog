---
interface Props {
  title: string
  description?: string
  image?: string
}

const { title, description = 'Cybersecurity insights, digital reports, and IT governance from Marco Cavani.', image } = Astro.props
const canonicalURL = new URL(Astro.url.pathname, Astro.site)

// Sitewide structured data (Organization + Person + WebSite). Individual
// articles add their own Article schema and reference these nodes by @id.
const siteUrl = (Astro.site?.href || 'https://marcoweb.org/').replace(/\/$/, '')
const siteSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: 'MarcoWeb',
      url: `${siteUrl}/`,
      logo: { '@type': 'ImageObject', url: `${siteUrl}/logo.png` },
      founder: { '@id': `${siteUrl}/#marco` },
    },
    {
      '@type': 'Person',
      '@id': `${siteUrl}/#marco`,
      name: 'Marco Cavani',
      url: `${siteUrl}/about/`,
      jobTitle: 'Cybersecurity Professional & IT Governance Specialist',
      worksFor: { '@id': `${siteUrl}/#organization` },
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      name: 'MarcoWeb',
      url: `${siteUrl}/`,
      description: 'Cybersecurity analysis, digital reports, and IT governance from Marco Cavani.',
      publisher: { '@id': `${siteUrl}/#organization` },
      inLanguage: 'en-AU',
    },
  ],
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" type="application/rss+xml" title="MarcoWeb RSS Feed" href="/rss.xml" />

    <!-- Structured data: Organization + Person + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="MarcoWeb" />
    <meta property="og:type" content="website" />
    {image && <meta property="og:image" content={image} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3362770372572725" crossorigin="anonymous"></script>

    <!-- Netlify Identity (required for /admin CMS login) -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <slot />
    <script>
      // Forward identity tokens to the custom reset page
      var _hash = window.location.hash
      if (_hash.includes('recovery_token') || _hash.includes('invite_token')) {
        window.location.replace('/reset-password/' + _hash)
      }
      // Redirect to /admin after Netlify Identity login
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/'
            })
          }
        })
      }
    </script>
  </body>
</html>
