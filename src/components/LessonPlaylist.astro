---
// The module's lessons as a playlist, so the course reads as a sequence rather
// than a set of unrelated pages. Sits above the quiz at the foot of a lesson.

interface Item {
  slug: string
  title: string
  minutes: number
  hasVideo: boolean
  questions: number
}

interface Props {
  items: Item[]
  currentSlug: string
  module: string
  playlistUrl?: string
}

const { items, currentSlug, module, playlistUrl } = Astro.props
---

<section class="mt-16">
  <div class="flex items-baseline gap-3 mb-5">
    <h2 class="text-xl font-bold text-gray-900">{module}</h2>
    <div class="flex-1 h-px bg-gray-200"></div>
    {playlistUrl && (
      <a href={playlistUrl} target="_blank" rel="noopener noreferrer"
         class="text-xs font-semibold text-brand-blue hover:text-brand-navy">Watch on YouTube</a>
    )}
  </div>

  <ol class="space-y-2">
    {items.map((l, i) => {
      const current = l.slug === currentSlug
      return (
        <li>
          <a
            href={`/training/${l.slug}/`}
            aria-current={current ? 'page' : undefined}
            class={`flex items-center gap-4 rounded-xl border p-4 transition-shadow group ${
              current
                ? 'border-brand-blue bg-blue-50/60'
                : 'border-gray-100 bg-white shadow-sm hover:shadow-md'
            }`}
          >
            <span class={`shrink-0 w-8 h-8 rounded-lg text-xs font-bold flex items-center justify-center ${
              current ? 'bg-brand-blue text-white' : 'bg-blue-50 text-brand-blue'
            }`}>
              {i + 1}
            </span>
            <span class="flex-1 min-w-0">
              <span class={`block font-semibold ${current ? 'text-brand-navy' : 'text-gray-900 group-hover:text-brand-blue'} transition-colors`}>
                {l.title}
              </span>
              <span class="block text-xs text-gray-400 mt-0.5">
                {l.hasVideo ? 'Video' : 'Written'} · {l.minutes} min
                {l.questions > 0 && ` · ${l.questions} questions`}
              </span>
            </span>
            {current && <span class="shrink-0 text-[11px] font-semibold uppercase tracking-wider text-brand-blue">Playing</span>}
          </a>
        </li>
      )
    })}
  </ol>
</section>
