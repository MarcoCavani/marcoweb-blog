---
interface Props {
  compact?: boolean
}
const { compact = false } = Astro.props
---

{compact ? (
  <form id="compact-nl-form" class="flex gap-2" novalidate>
    <input
      type="email"
      id="compact-nl-email"
      name="email"
      placeholder="your@email.com"
      required
      class="flex-1 px-3 py-2 rounded-lg bg-gray-800 border border-gray-600 text-white placeholder-gray-500 text-sm focus:outline-none focus:border-brand-blue"
    />
    <button
      type="submit"
      id="compact-nl-btn"
      class="px-3 py-2 bg-brand-blue hover:bg-brand-light text-white rounded-lg text-sm font-medium transition-colors whitespace-nowrap"
    >
      Subscribe
    </button>
  </form>
  <p id="compact-nl-msg" class="text-xs mt-2" style="display:none"></p>

  <script is:inline>
  (function () {
    var form = document.getElementById('compact-nl-form')
    if (!form) return
    form.addEventListener('submit', async function (e) {
      e.preventDefault()
      var email = document.getElementById('compact-nl-email').value.trim()
      var btn = document.getElementById('compact-nl-btn')
      var msg = document.getElementById('compact-nl-msg')
      if (!email || !email.includes('@')) {
        msg.textContent = 'Enter a valid email.'
        msg.style.color = '#f87171'
        msg.style.display = 'block'
        return
      }
      btn.disabled = true
      btn.textContent = '...'
      try {
        var res = await fetch('/.netlify/functions/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email }),
        })
        if (res.ok) {
          form.style.display = 'none'
          msg.textContent = "You're in! Watch your inbox."
          msg.style.color = '#86efac'
          msg.style.display = 'block'
        } else {
          throw new Error()
        }
      } catch {
        btn.disabled = false
        btn.textContent = 'Subscribe'
        msg.textContent = 'Something went wrong. Try again.'
        msg.style.color = '#f87171'
        msg.style.display = 'block'
      }
    })
  })()
  </script>
) : (
  <div class="bg-brand-navy rounded-2xl p-8 text-white text-center">
    <h3 class="text-2xl font-bold mb-2">Stay ahead of cyber threats</h3>
    <p class="text-gray-300 mb-6 max-w-md mx-auto">
      Get the latest cybersecurity reports, threat intelligence, and IT governance insights delivered straight to your inbox. No spam. Unsubscribe any time.
    </p>

    <div id="nl-form-wrap">
      <form id="nl-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" novalidate>
        <input
          type="email"
          id="nl-email"
          name="email"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-brand-light focus:bg-white/20 transition-all"
        />
        <button
          type="submit"
          id="nl-btn"
          class="px-6 py-3 bg-brand-blue hover:bg-brand-light text-white font-semibold rounded-xl transition-colors whitespace-nowrap"
        >
          Subscribe Free
        </button>
      </form>
      <p id="nl-error" class="text-red-400 text-xs mt-3" style="display:none">
        Something went wrong. Please try again.
      </p>
    </div>

    <div id="nl-success" style="display:none">
      <p class="text-brand-light text-lg font-semibold mb-1">You're in!</p>
      <p class="text-gray-300 text-sm">Thanks for subscribing. Watch your inbox for the next report.</p>
    </div>

    <p id="nl-fine" class="text-xs text-gray-500 mt-3">No spam. Unsubscribe at any time.</p>
  </div>
)}

<script is:inline>
(function () {
  var form = document.getElementById('nl-form')
  if (!form) return

  form.addEventListener('submit', async function (e) {
    e.preventDefault()
    var email = document.getElementById('nl-email').value.trim()
    var btn = document.getElementById('nl-btn')
    var errorEl = document.getElementById('nl-error')

    if (!email || !email.includes('@')) {
      errorEl.textContent = 'Please enter a valid email address.'
      errorEl.style.display = 'block'
      return
    }

    btn.disabled = true
    btn.textContent = 'Subscribing…'
    errorEl.style.display = 'none'

    try {
      var res = await fetch('/.netlify/functions/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email }),
      })

      if (res.ok) {
        document.getElementById('nl-form-wrap').style.display = 'none'
        document.getElementById('nl-fine').style.display = 'none'
        document.getElementById('nl-success').style.display = 'block'
      } else {
        throw new Error('failed')
      }
    } catch {
      btn.disabled = false
      btn.textContent = 'Subscribe Free'
      errorEl.textContent = 'Something went wrong. Please try again.'
      errorEl.style.display = 'block'
    }
  })
})()
</script>
