---
const currentPath = Astro.url.pathname
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/')
---

<header class="bg-white border-b border-gray-200 shadow-sm sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3 group">
        <img src="/logo.png" alt="MarcoWeb" class="h-9 w-auto" />
        <span class="text-xl font-bold tracking-tight text-gray-900 group-hover:text-brand-blue transition-colors">MarcoWeb</span>
      </a>

      <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
        <a href="/" class={`transition-colors hover:text-brand-blue ${isActive('/') && currentPath === '/' ? 'text-brand-blue' : 'text-gray-500'}`}>
          Home
        </a>
        <a href="/blog" class={`transition-colors hover:text-brand-blue ${isActive('/blog') ? 'text-brand-blue' : 'text-gray-500'}`}>
          Blog
        </a>
        <a href="/reports" class={`transition-colors hover:text-brand-blue ${isActive('/reports') ? 'text-brand-blue' : 'text-gray-500'}`}>
          Reports
        </a>
        <a href="/training" class={`transition-colors hover:text-brand-blue ${isActive('/training') ? 'text-brand-blue' : 'text-gray-500'}`}>
          Training
        </a>
        <a href="/about" class={`transition-colors hover:text-brand-blue ${isActive('/about') ? 'text-brand-blue' : 'text-gray-500'}`}>
          About
        </a>
        <a href="/contact" class={`transition-colors hover:text-brand-blue ${isActive('/contact') ? 'text-brand-blue' : 'text-gray-500'}`}>
          Contact
        </a>
<a
          href="https://itgc.marcoweb.org"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brand-blue hover:bg-brand-light text-white px-4 py-1.5 rounded-full transition-colors text-sm font-semibold"
        >
          ITGC Tool ↗
        </a>
      </nav>

      <!-- Mobile nav -->
      <div class="md:hidden flex items-center gap-4">
        <a href="/blog" class="text-gray-500 hover:text-brand-blue text-sm">Blog</a>
        <a
          href="https://itgc.marcoweb.org"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brand-blue hover:bg-brand-light text-white px-3 py-1 rounded-full text-xs font-semibold transition-colors"
        >
          ITGC ↗
        </a>
      </div>
    </div>
  </div>
</header>
