---
const currentPath = Astro.url.pathname
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/')
---

<header class="bg-brand-navy text-white shadow-lg sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3 group">
        <img
          src="/logo.png"
          alt="MarcoWeb"
          class="w-9 h-9 rounded-lg"
        />
        <span class="text-xl font-bold tracking-tight group-hover:text-brand-light transition-colors">MarcoWeb</span>
      </a>

      <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
        <a href="/" class={`transition-colors hover:text-brand-light ${isActive('/') && currentPath === '/' ? 'text-brand-light' : 'text-gray-300'}`}>
          Home
        </a>
        <a href="/blog" class={`transition-colors hover:text-brand-light ${isActive('/blog') ? 'text-brand-light' : 'text-gray-300'}`}>
          Blog
        </a>
        <a href="/reports" class={`transition-colors hover:text-brand-light ${isActive('/reports') ? 'text-brand-light' : 'text-gray-300'}`}>
          Reports
        </a>
        <a href="/about" class={`transition-colors hover:text-brand-light ${isActive('/about') ? 'text-brand-light' : 'text-gray-300'}`}>
          About
        </a>
<a
          href="https://marcoweb-itgc-saas.netlify.app"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brand-blue hover:bg-brand-light text-white px-4 py-1.5 rounded-full transition-colors text-sm font-semibold"
        >
          ITGC Tool ↗
        </a>
      </nav>

      <!-- Mobile nav -->
      <div class="md:hidden flex items-center gap-4">
        <a href="/blog" class="text-gray-300 hover:text-white text-sm">Blog</a>
        <a
          href="https://marcoweb-itgc-saas.netlify.app"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-brand-blue hover:bg-brand-light text-white px-3 py-1 rounded-full text-xs font-semibold transition-colors"
        >
          ITGC ↗
        </a>
      </div>
    </div>
  </div>
</header>
