---
interface Props {
  variant?: 'inline' | 'full'
}
const { variant = 'inline' } = Astro.props
---

<div class={`my-8 rounded-2xl overflow-hidden border border-blue-200 ${variant === 'full' ? 'bg-gradient-to-r from-brand-navy to-brand-blue text-white' : 'bg-blue-50'}`}>
  <div class="p-6 md:p-8 flex flex-col md:flex-row items-center gap-6">
    <div class="flex-1">
      {variant === 'full' ? (
        <>
          <div class="text-xs font-semibold uppercase tracking-widest text-blue-300 mb-1">ITGC Audit Tool</div>
          <h3 class="text-xl font-bold mb-2 text-white">Streamline Your IT General Controls Audits</h3>
          <p class="text-blue-100 text-sm leading-relaxed">
            The RACM ITGC SaaS platform helps audit professionals manage IT General Controls assessments — from risk and control mapping to workpaper generation and evidence tracking.
          </p>
        </>
      ) : (
        <>
          <div class="text-xs font-semibold uppercase tracking-widest text-brand-blue mb-1">Audit Tool</div>
          <h3 class="text-lg font-bold text-gray-900 mb-1">Automate Your ITGC Assessments</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Use the RACM ITGC tool to manage risk and control matrices, generate professional audit workpapers, and export findings to Excel.
          </p>
        </>
      )}
    </div>
    <div class="shrink-0">
      <a
        href="https://marcoweb-itgc-saas.netlify.app"
        target="_blank"
        rel="noopener noreferrer"
        class={`inline-block px-6 py-3 rounded-xl font-semibold text-sm transition-all ${
          variant === 'full'
            ? 'bg-white text-brand-navy hover:bg-blue-50'
            : 'bg-brand-blue text-white hover:bg-brand-navy'
        }`}
      >
        Try It Free →
      </a>
    </div>
  </div>
</div>
