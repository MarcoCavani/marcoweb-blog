---
interface Question {
  question: string
  options: string[]
  answer: number
  explanation: string
  // Parallel to `options`. Why the option you picked is attractive but wrong.
  // Shown above the main explanation, because on a certification question
  // knowing why your own reasoning failed matters more than the right answer.
  whyWrong?: string[]
}

interface Props {
  questions: Question[]
  id?: string
}

const { questions, id = 'quiz' } = Astro.props
// The answer key is rendered into the markup, so a determined reader can find it.
// That is an acceptable trade for a knowledge check, it is not an exam, and the
// explanations are the point. Do not reuse this component for anything assessed.
---

<section class="mt-12 rounded-2xl border border-blue-200 bg-blue-50/50 p-6 md:p-8" data-quiz id={id}>
  <div class="flex items-center gap-3 mb-6">
    <span class="text-xs font-semibold uppercase tracking-widest text-brand-blue">Knowledge check</span>
    <div class="flex-1 h-px bg-blue-200"></div>
    <span class="text-xs text-gray-500" data-quiz-progress>0 / {questions.length}</span>
  </div>

  <ol class="space-y-8">
    {questions.map((q, qi) => (
      <li data-question={qi} data-answer={q.answer}>
        <p class="font-semibold text-gray-900 mb-4">
          <span class="text-brand-blue mr-2">{qi + 1}.</span>{q.question}
        </p>
        <div class="space-y-2">
          {q.options.map((opt, oi) => (
            <button
              type="button"
              data-option={oi}
              data-why={oi === q.answer ? undefined : q.whyWrong?.[oi]}
              class="quiz-option w-full text-left text-sm px-4 py-3 rounded-xl border border-gray-200 bg-white text-gray-700 hover:border-brand-blue hover:text-brand-blue transition-colors"
            >
              {opt}
            </button>
          ))}
        </div>
        <div class="quiz-explain hidden mt-3 text-sm rounded-xl p-4 leading-relaxed" data-explanation>
          <p class="hidden mb-3 pb-3 border-b" data-why-wrong></p>
          <span>{q.explanation}</span>
        </div>
      </li>
    ))}
  </ol>

  <div class="hidden mt-8 pt-6 border-t border-blue-200 text-center" data-quiz-result>
    <p class="text-2xl font-extrabold text-gray-900" data-quiz-score></p>
    <p class="text-sm text-gray-500 mt-1" data-quiz-message></p>
    <button
      type="button"
      data-quiz-reset
      class="mt-4 text-xs font-semibold text-brand-blue hover:text-brand-navy"
    >
      Try again
    </button>
  </div>
</section>

<script is:inline>
  (function () {
    document.querySelectorAll('[data-quiz]').forEach(function (quiz) {
      var questions = quiz.querySelectorAll('[data-question]')
      var progress = quiz.querySelector('[data-quiz-progress]')
      var result = quiz.querySelector('[data-quiz-result]')
      var scoreEl = quiz.querySelector('[data-quiz-score]')
      var msgEl = quiz.querySelector('[data-quiz-message]')
      var resetBtn = quiz.querySelector('[data-quiz-reset]')
      var total = questions.length
      var answered, correct

      function reset() {
        answered = 0
        correct = 0
        result.classList.add('hidden')
        progress.textContent = '0 / ' + total
        questions.forEach(function (q) {
          q.removeAttribute('data-done')
          q.querySelector('[data-explanation]').classList.add('hidden')
          var w = q.querySelector('[data-why-wrong]')
          if (w) { w.textContent = ''; w.className = 'hidden' }
          q.querySelectorAll('.quiz-option').forEach(function (b) {
            b.disabled = false
            b.className = 'quiz-option w-full text-left text-sm px-4 py-3 rounded-xl border border-gray-200 bg-white text-gray-700 hover:border-brand-blue hover:text-brand-blue transition-colors'
          })
        })
      }

      questions.forEach(function (q) {
        var right = parseInt(q.dataset.answer, 10)
        var explain = q.querySelector('[data-explanation]')

        q.querySelectorAll('.quiz-option').forEach(function (btn) {
          btn.addEventListener('click', function () {
            if (q.hasAttribute('data-done')) return
            q.setAttribute('data-done', '1')
            var picked = parseInt(btn.dataset.option, 10)
            var isRight = picked === right
            if (isRight) correct++
            answered++

            q.querySelectorAll('.quiz-option').forEach(function (b) {
              var i = parseInt(b.dataset.option, 10)
              b.disabled = true
              if (i === right) {
                b.className = 'quiz-option w-full text-left text-sm px-4 py-3 rounded-xl border-2 border-green-500 bg-green-50 text-green-900 font-medium'
              } else if (i === picked) {
                b.className = 'quiz-option w-full text-left text-sm px-4 py-3 rounded-xl border-2 border-red-400 bg-red-50 text-red-900'
              } else {
                b.className = 'quiz-option w-full text-left text-sm px-4 py-3 rounded-xl border border-gray-200 bg-white text-gray-400'
              }
            })

            explain.className = isRight
              ? 'quiz-explain mt-3 text-sm rounded-xl p-4 leading-relaxed bg-green-50 text-green-900 border border-green-200'
              : 'quiz-explain mt-3 text-sm rounded-xl p-4 leading-relaxed bg-white text-gray-700 border border-gray-200'

            // On a wrong pick, lead with why that specific option failed. The
            // candidate already believes it; correcting their reasoning is the
            // point of the question.
            var whyEl = explain.querySelector('[data-why-wrong]')
            if (whyEl) {
              var why = btn.getAttribute('data-why')
              if (!isRight && why) {
                whyEl.textContent = why
                whyEl.className = 'mb-3 pb-3 border-b border-gray-200 text-gray-900'
              } else {
                whyEl.textContent = ''
                whyEl.className = 'hidden'
              }
            }

            progress.textContent = answered + ' / ' + total

            if (answered === total) {
              scoreEl.textContent = correct + ' out of ' + total
              msgEl.textContent = correct === total
                ? 'Full marks, you can explain this control to an auditor.'
                : correct >= Math.ceil(total * 0.7)
                  ? 'Solid. Re-read the explanations you missed.'
                  : 'Worth another pass through the lesson before moving on.'
              result.classList.remove('hidden')
            }
          })
        })
      })

      resetBtn.addEventListener('click', reset)
      reset()
    })
  })()
</script>
