---
// Lesson video with the transcript beside it, highlighted sentence by sentence
// as the narration reaches it.
//
// The sentence is the unit meaning arrives in, so it is the unit that gets
// highlighted. Word-level tracking was tried and rejected: something changing
// every third of a second pulls the eye constantly and makes reading ahead
// uncomfortable over an hour. Sentence timings also come straight out of the
// SRT files the video pipeline already produces, where word timings would need
// forced alignment.
//
// Transcript data is generated by _build/make-transcript.mjs into
// src/data/transcripts/<lesson-slug>.json. Paragraphs follow slide boundaries,
// because one slide is one thought.

interface Sentence { t: number; text: string }
interface Paragraph { t: number; sentences: Sentence[] }

interface Props {
  videoId: string
  title: string
  paragraphs: Paragraph[]
}

const { videoId, title, paragraphs } = Astro.props

// Flattened once here so the client script does not have to walk the tree to
// find which sentence is current.
const flat = paragraphs.flatMap((p, pi) =>
  p.sentences.map(s => ({ t: s.t, p: pi }))
)
---

<div class="mb-10" data-transcript-player data-video={videoId}>
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.6fr)_minmax(0,1fr)] gap-5 items-start">
    <!-- Video. Leads the layout; the transcript is the companion, not the peer. -->
    <div class="min-w-0">
      <div class="relative rounded-2xl overflow-hidden bg-black shadow-sm" style="aspect-ratio:16/9">
        <div class="absolute inset-0" data-yt-mount>
          <!-- The iframe is created by the script once the API is ready. Before
               that, a still frame with a play control so the block is never
               empty and works without JavaScript as a link to YouTube. -->
          <noscript>
            <a
              href={`https://www.youtube.com/watch?v=${videoId}`}
              class="absolute inset-0 grid place-items-center bg-brand-navy text-white text-sm font-semibold"
            >Watch this lesson on YouTube</a>
          </noscript>
        </div>
      </div>
    </div>

    <!-- Transcript. Fixed height, matched to the video on desktop. -->
    <div class="rounded-2xl border border-gray-100 bg-white shadow-sm overflow-hidden flex flex-col">
      <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-100">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400">Transcript</h2>
        <button
          type="button"
          data-follow
          aria-pressed="true"
          class="ml-auto flex items-center gap-1.5 rounded-full border border-brand-blue bg-blue-50 px-2.5 py-1 text-[11px] font-semibold text-brand-blue transition-colors"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
          Follow
        </button>
      </div>

      <div class="relative flex-1 min-h-0">
        <div
          class="overflow-y-auto px-5 py-4 text-[15px] leading-relaxed text-gray-600 h-[300px] lg:h-[var(--transcript-h,380px)]"
          data-doc
        >
          {paragraphs.map((para, pi) => (
            <p class="mb-4" data-para={pi}>
              {para.sentences.map(s => (
                <span
                  class="cursor-pointer rounded transition-colors hover:text-brand-blue"
                  data-t={s.t}
                >{s.text}{' '}</span>
              ))}
            </p>
          ))}
        </div>

        <button
          type="button"
          data-resume
          hidden
          class="absolute left-1/2 -translate-x-1/2 bottom-3 rounded-full bg-brand-navy px-3.5 py-1.5 text-[11px] font-semibold text-white shadow-lg"
        >
          Back to the voice
        </button>
      </div>
    </div>
  </div>
</div>

<script type="application/json" data-transcript-cues set:html={JSON.stringify(flat)}></script>

<style>
  /* The YouTube IFrame API creates its iframe with fixed width="640"
     height="360" attributes and no filling CSS, so on any container narrower
     than 640px, every mobile screen, it overflowed and got clipped to a
     zoomed-in top-left slice. Force it to fill the 16:9 box.
     Must be :global, because the iframe is created by YouTube at runtime and
     never carries Astro's scoped-style attribute, so a scoped rule would not
     match it. LessonVideo.astro escapes this because its iframe is a static
     w-full h-full element in the markup. */
  :global([data-yt-mount] iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Highlight states. Kept in a style block rather than utility classes because
     the script toggles them on many spans and shorter class names keep the
     toggling cheap. */
  [data-doc] span.is-done { color: #9aa5ac; }
  [data-doc] span.is-now {
    background: #cfe9f7;
    color: #111111;
    font-weight: 600;
    box-shadow: 0 0 0 3px #cfe9f7;
    border-radius: 2px;
  }
</style>

<script is:inline>
  (function () {
    var root = document.querySelector('[data-transcript-player]')
    if (!root) return

    var cues = JSON.parse(document.querySelector('[data-transcript-cues]').textContent)
    var doc = root.querySelector('[data-doc]')
    var followBtn = root.querySelector('[data-follow]')
    var resumeBtn = root.querySelector('[data-resume]')
    var mount = root.querySelector('[data-yt-mount]')
    var spans = Array.prototype.slice.call(doc.querySelectorAll('span[data-t]'))
    var paras = Array.prototype.slice.call(doc.querySelectorAll('[data-para]'))

    var player = null
    var follow = true
    var lastIndex = -1
    var poll = null

    // Match the transcript box to the video height on desktop so the two
    // columns line up. Recomputed on resize because the video is fluid.
    function sizeBox() {
      var video = root.querySelector('.relative.rounded-2xl')
      if (!video) return
      var h = video.getBoundingClientRect().height
      if (h > 0) root.style.setProperty('--transcript-h', Math.round(h) + 'px')
    }
    sizeBox()
    window.addEventListener('resize', sizeBox)

    function setFollow(on) {
      follow = on
      followBtn.setAttribute('aria-pressed', on ? 'true' : 'false')
      followBtn.className = on
        ? 'ml-auto flex items-center gap-1.5 rounded-full border border-brand-blue bg-blue-50 px-2.5 py-1 text-[11px] font-semibold text-brand-blue transition-colors'
        : 'ml-auto flex items-center gap-1.5 rounded-full border border-gray-200 bg-white px-2.5 py-1 text-[11px] font-semibold text-gray-400 transition-colors'
      resumeBtn.hidden = on
      if (on && lastIndex >= 0) scrollToSpan(spans[lastIndex])
    }

    function scrollToSpan(el) {
      if (!el) return
      // Measured from bounding rects, not offsetTop: the spans' offsetParent is
      // not the scrolling box, so offsetTop would be relative to the wrong
      // element and only looks right while their top edges happen to coincide.
      var boxRect = doc.getBoundingClientRect()
      var r = el.getBoundingClientRect()
      var delta = (r.top - boxRect.top) - (doc.clientHeight / 2) + (r.height / 2)
      var max = doc.scrollHeight - doc.clientHeight
      doc.scrollTo({ top: Math.min(max, Math.max(0, doc.scrollTop + delta)), behavior: 'smooth' })
    }

    function indexAt(time) {
      var found = -1
      for (var i = 0; i < cues.length; i++) {
        if (cues[i].t <= time + 0.001) found = i
        else break
      }
      return found
    }

    function paint(time) {
      var i = indexAt(time)
      if (i === lastIndex) return
      // Set both classes from the current index rather than clearing a
      // remembered previous one, so a seek cannot leave a stale highlight
      // behind and show two active sentences at once.
      for (var n = 0; n < spans.length; n++) {
        var s = spans[n]
        var done = n < i
        var now = n === i
        if (s.classList.contains('is-done') !== done) s.classList.toggle('is-done', done)
        if (s.classList.contains('is-now') !== now) s.classList.toggle('is-now', now)
      }
      if (follow && i >= 0) scrollToSpan(spans[i])
      lastIndex = i
    }

    function seek(t) {
      if (player && player.seekTo) {
        player.seekTo(t, true)
        if (player.playVideo) player.playVideo()
      }
      paint(t)
    }

    spans.forEach(function (s) {
      s.addEventListener('click', function () {
        setFollow(true)
        seek(parseFloat(s.dataset.t))
      })
    })

    // Yield on real user intent rather than on scroll events. Watching `scroll`
    // cannot distinguish our own smooth scrolling from the reader's, and the
    // animation keeps firing events after any reasonable guard expires, so the
    // panel ends up disengaging itself.
    var yieldKeys = { ArrowUp: 1, ArrowDown: 1, PageUp: 1, PageDown: 1, Home: 1, End: 1 }
    function yieldFollow() { if (follow) setFollow(false) }
    doc.addEventListener('wheel', yieldFollow, { passive: true })
    doc.addEventListener('touchmove', yieldFollow, { passive: true })
    doc.addEventListener('keydown', function (e) { if (yieldKeys[e.key]) yieldFollow() })
    followBtn.addEventListener('click', function () {
      setFollow(followBtn.getAttribute('aria-pressed') !== 'true')
    })
    resumeBtn.addEventListener('click', function () { setFollow(true) })

    function startPolling() {
      if (poll) return
      // The IFrame API has no timeupdate event, so the current time has to be
      // polled. Four times a second is enough to land a sentence highlight
      // without spending much.
      poll = setInterval(function () {
        if (player && player.getCurrentTime) paint(player.getCurrentTime())
      }, 250)
    }
    function stopPolling() { if (poll) { clearInterval(poll); poll = null } }

    function makePlayer() {
      var holder = document.createElement('div')
      mount.appendChild(holder)
      player = new YT.Player(holder, {
        videoId: root.dataset.video,
        host: 'https://www.youtube-nocookie.com',
        playerVars: { rel: 0, modestbranding: 1, playsinline: 1 },
        events: {
          onReady: function () { sizeBox() },
          onStateChange: function (e) {
            if (e.data === YT.PlayerState.PLAYING) startPolling()
            else if (e.data === YT.PlayerState.ENDED || e.data === YT.PlayerState.PAUSED) {
              stopPolling()
              if (player.getCurrentTime) paint(player.getCurrentTime())
            }
          },
        },
      })
    }

    // Load the IFrame API once, and only on pages that actually have a video.
    if (window.YT && window.YT.Player) {
      makePlayer()
    } else {
      var prev = window.onYouTubeIframeAPIReady
      window.onYouTubeIframeAPIReady = function () {
        if (typeof prev === 'function') prev()
        makePlayer()
      }
      if (!document.querySelector('script[src*="youtube.com/iframe_api"]')) {
        var tag = document.createElement('script')
        tag.src = 'https://www.youtube.com/iframe_api'
        document.head.appendChild(tag)
      }
    }
  })()
</script>
