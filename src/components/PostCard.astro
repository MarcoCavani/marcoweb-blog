---
interface Props {
  title: string
  description: string
  slug: string
  pubDate: Date
  category: string
  readTime?: string
  heroImage?: string
  tags?: string[]
  basePath?: string
}

const { title, description, slug, pubDate, category, readTime, heroImage, tags, basePath = '/blog' } = Astro.props

const formattedDate = new Intl.DateTimeFormat('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(pubDate)
---

<article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow group">
  {heroImage && (
    <a href={`${basePath}/${slug}`}>
      <img
        src={heroImage}
        alt={title}
        class="w-full h-48 object-cover group-hover:opacity-95 transition-opacity"
        loading="lazy"
      />
    </a>
  )}

  <div class="p-6">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-xs font-semibold uppercase tracking-widest text-brand-blue bg-fuchsia-50 px-2.5 py-1 rounded-full">
        {category}
      </span>
      {readTime && (
        <span class="text-xs text-gray-400">{readTime}</span>
      )}
    </div>

    <h2 class="text-lg font-bold text-gray-900 mb-2 leading-snug group-hover:text-brand-blue transition-colors">
      <a href={`${basePath}/${slug}`}>{title}</a>
    </h2>

    <p class="text-gray-500 text-sm leading-relaxed mb-4 line-clamp-3">
      {description}
    </p>

    <div class="flex items-center justify-between">
      <time class="text-xs text-gray-400" datetime={pubDate.toISOString()}>
        {formattedDate}
      </time>
      <a
        href={`${basePath}/${slug}`}
        class="text-sm font-semibold text-brand-blue hover:text-brand-navy transition-colors"
      >
        Read more →
      </a>
    </div>

    {tags && tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map(tag => (
          <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</article>
