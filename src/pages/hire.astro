---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<Layout
  title="Hire Me | Marco Cavani, IT Audit & Cybersecurity"
  description="Marco Cavani is available for IT audit, GRC consulting, and cybersecurity advisory roles. Based in Perth, WA. Open to full-time, contract, and consulting engagements."
>
  <Header />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Hero -->
    <div class="mb-12">
      <span class="inline-flex items-center gap-2 bg-green-50 text-green-700 border border-green-200 text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        Available for new opportunities
      </span>
      <h1 class="text-4xl font-extrabold text-gray-900 mb-3">Work with Me</h1>
      <p class="text-xl text-gray-500 leading-relaxed">
        IT audit and cybersecurity professional based in Perth, WA, open to full-time, contract, and consulting roles across Australia.
      </p>
    </div>

    <!-- What I offer -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 mb-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">What I Do</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="flex gap-3 items-start">
          <span class="text-brand-blue text-xl mt-0.5">📋</span>
          <div>
            <p class="font-semibold text-gray-800">ITGC Auditing</p>
            <p class="text-sm text-gray-500">IT General Controls assessments across access management, change management, operations, and information security</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="text-brand-blue text-xl mt-0.5">🏛️</span>
          <div>
            <p class="font-semibold text-gray-800">GRC Consulting</p>
            <p class="text-sm text-gray-500">Governance, risk, and compliance advisory aligned to SOX, APRA, ISO 27001, and Essential Eight</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="text-brand-blue text-xl mt-0.5">🔐</span>
          <div>
            <p class="font-semibold text-gray-800">Cyber Risk Assessment</p>
            <p class="text-sm text-gray-500">Risk identification, vulnerability analysis, control gap assessment, and remediation planning</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="text-brand-blue text-xl mt-0.5">🛡️</span>
          <div>
            <p class="font-semibold text-gray-800">Security Policy & Advisory</p>
            <p class="text-sm text-gray-500">Information security policy development, standards alignment, and stakeholder communication</p>
          </div>
        </div>
      </div>
    </div>

    <!-- LinkedIn -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 mb-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">LinkedIn</h2>
      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href="https://linkedin.com/in/marcoweb2024"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 bg-brand-blue hover:bg-brand-light text-white font-semibold px-6 py-3 rounded-full transition-colors text-sm"
        >
          linkedin.com/in/marcoweb2024 ↗
        </a>
      </div>
    </div>

    <!-- CTA -->
    <div class="bg-brand-navy text-white rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold mb-3">Get in Touch</h2>
      <p class="text-gray-300 mb-6">
        Hiring for an IT audit, GRC, or cybersecurity role? Reach out directly.
      </p>
      <a
        href="mailto:marco@marcoweb.org"
        class="inline-block bg-brand-blue hover:bg-brand-light text-white font-semibold px-8 py-3 rounded-full transition-colors"
      >
        marco@marcoweb.org
      </a>
    </div>

  </main>

  <Footer />
</Layout>
