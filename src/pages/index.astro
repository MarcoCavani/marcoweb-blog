---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import PostCard from '../components/PostCard.astro'
import CTABox from '../components/CTABox.astro'
import NewsletterSignup from '../components/NewsletterSignup.astro'
import AdBanner from '../components/AdBanner.astro'
import { getCollection } from 'astro:content'

const today = new Date()
today.setHours(23, 59, 59, 999)
const allPosts = (await getCollection('blog'))
  .filter(p => p.data.pubDate <= today)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const reports = allPosts.filter(p => p.data.category === 'Digital Report')
const blogPosts = allPosts.filter(p => p.data.category !== 'Digital Report')

const featuredPost = blogPosts[0]
const recentPosts = blogPosts.slice(1, 5)
---

<Layout title="MarcoWeb | Cybersecurity Insights and Digital Reports">
  <Header />

  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-gray-900 via-gray-900 to-gray-800 text-white py-20 px-4 relative overflow-hidden">
      <canvas id="hero-canvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>
      <div class="max-w-4xl mx-auto text-center relative">
        <div class="hero-anim inline-block text-xs font-semibold uppercase tracking-widest text-brand-light bg-white/10 px-4 py-1.5 rounded-full mb-6">
          Cybersecurity · IT Governance · Digital Reports
        </div>
        <h1 class="hero-anim text-4xl sm:text-5xl font-extrabold leading-tight mb-6">
          <span id="hero-headline">Cyber Threats Don't Wait.</span><br />
          <span class="text-brand-light">Neither Should You.</span>
        </h1>
        <p class="hero-anim text-lg text-gray-300 leading-relaxed max-w-2xl mx-auto mb-8">
          In-depth cybersecurity analysis, threat intelligence, and IT governance insights from Marco Cavani, helping professionals understand and manage digital risk.
        </p>
        <div class="hero-anim flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/blog" class="px-8 py-3 bg-brand-blue hover:bg-brand-light text-white font-semibold rounded-xl transition-colors">
            Read the Blog
          </a>
          <a
            href="https://marcoweb-itgc-saas.netlify.app"
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-3 bg-white/10 hover:bg-white/20 text-white font-semibold rounded-xl border border-white/20 transition-colors"
          >
            ITGC Audit Tool ↗
          </a>
        </div>
      </div>
    </section>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

      <!-- Ad -->
      <AdBanner slot="leaderboard" />

      <!-- Featured post -->
      {featuredPost && (
        <section class="mb-16">
          <div class="flex items-center gap-3 mb-6">
            <h2 class="text-2xl font-bold text-gray-900">Featured Report</h2>
            <div class="flex-1 h-px bg-gray-200"></div>
          </div>
          <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden md:flex group hover:shadow-md transition-shadow">
            {featuredPost.data.heroImage && (
              <a href={`/blog/${featuredPost.slug}`} class="md:w-80 shrink-0">
                <img
                  src={featuredPost.data.heroImage}
                  alt={featuredPost.data.title}
                  class="w-full h-56 md:h-full object-cover group-hover:opacity-95 transition-opacity"
                />
              </a>
            )}
            <div class="p-8 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-semibold uppercase tracking-widest text-brand-blue bg-blue-50 px-2.5 py-1 rounded-full">
                  {featuredPost.data.category}
                </span>
                {featuredPost.data.readTime && (
                  <span class="text-xs text-gray-400">{featuredPost.data.readTime}</span>
                )}
              </div>
              <h3 class="text-2xl font-bold text-gray-900 mb-3 leading-tight group-hover:text-brand-blue transition-colors">
                <a href={`/blog/${featuredPost.slug}`}>{featuredPost.data.title}</a>
              </h3>
              <p class="text-gray-500 leading-relaxed mb-5">{featuredPost.data.description}</p>
              <a
                href={`/blog/${featuredPost.slug}`}
                class="self-start px-5 py-2 bg-brand-blue hover:bg-brand-navy text-white rounded-xl text-sm font-semibold transition-colors"
              >
                Read more →
              </a>
            </div>
          </article>
        </section>
      )}

      <!-- CTA inline -->
      <CTABox variant="inline" />

      <!-- Recent blog posts -->
      {recentPosts.length > 0 && (
        <section class="mt-16">
          <div class="flex items-center gap-3 mb-6">
            <h2 class="text-2xl font-bold text-gray-900">Latest from the Blog</h2>
            <div class="flex-1 h-px bg-gray-200"></div>
            <a href="/blog" class="text-sm text-brand-blue hover:text-brand-navy font-medium transition-colors">View all →</a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {recentPosts.map(post => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                slug={post.slug}
                pubDate={post.data.pubDate}
                category={post.data.category}
                readTime={post.data.readTime}
                heroImage={post.data.heroImage}
                tags={post.data.tags}
                basePath="/blog"
              />
            ))}
          </div>
        </section>
      )}

      <!-- Digital Reports -->
      {reports.length > 0 && (
        <section class="mt-16">
          <div class="flex items-center gap-3 mb-6">
            <h2 class="text-2xl font-bold text-gray-900">Digital Reports</h2>
            <div class="flex-1 h-px bg-gray-200"></div>
            <a href="/reports" class="text-sm text-brand-blue hover:text-brand-navy font-medium transition-colors">View all →</a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {reports.map(post => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                slug={post.slug}
                pubDate={post.data.pubDate}
                category={post.data.category}
                readTime={post.data.readTime}
                heroImage={post.data.heroImage}
                tags={post.data.tags}
                basePath="/reports"
              />
            ))}
          </div>
        </section>
      )}

      <!-- Newsletter -->
      <div class="mt-16">
        <NewsletterSignup />
      </div>

      <!-- Full CTA -->
      <CTABox variant="full" />

      <!-- Bottom ad -->
      <AdBanner slot="leaderboard" />
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .hero-anim {
    opacity: 0;
    transform: translateY(18px);
  }
</style>

<script is:inline>
(function () {
  // Particle network canvas
  var cv = document.getElementById('hero-canvas');
  if (cv) {
    var cx = cv.getContext('2d');
    var pts = [];
    function initCv() {
      cv.width = cv.offsetWidth;
      cv.height = cv.offsetHeight;
      pts = Array.from({ length: 35 }, function () {
        return {
          x: Math.random() * cv.width,
          y: Math.random() * cv.height,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          r: Math.random() * 1.5 + 0.7,
        };
      });
    }
    function drawCv() {
      cx.clearRect(0, 0, cv.width, cv.height);
      for (var i = 0; i < pts.length; i++) {
        for (var j = i + 1; j < pts.length; j++) {
          var dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y;
          var d = Math.sqrt(dx * dx + dy * dy);
          if (d < 110) {
            cx.beginPath();
            cx.strokeStyle = 'rgba(51,153,204,' + (1 - d / 110) * 0.35 + ')';
            cx.lineWidth = 0.5;
            cx.moveTo(pts[i].x, pts[i].y);
            cx.lineTo(pts[j].x, pts[j].y);
            cx.stroke();
          }
        }
      }
      pts.forEach(function (p) {
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0 || p.x > cv.width) p.vx *= -1;
        if (p.y < 0 || p.y > cv.height) p.vy *= -1;
        cx.beginPath();
        cx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        cx.fillStyle = 'rgba(51,153,204,0.55)';
        cx.fill();
      });
      requestAnimationFrame(drawCv);
    }
    initCv();
    drawCv();
    window.addEventListener('resize', initCv);
  }

  // Stagger fade-up
  document.querySelectorAll('.hero-anim').forEach(function (el, i) {
    setTimeout(function () {
      el.style.transition = 'opacity 0.65s ease, transform 0.65s ease';
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }, 100 + i * 170);
  });

  // Glitch on headline
  var gEl = document.getElementById('hero-headline');
  if (gEl) {
    var orig = gEl.textContent;
    var chars = '!<>-_\\/[]{}=+*^?#';
    function doGlitch() {
      var iter = 0;
      var iv = setInterval(function () {
        gEl.textContent = orig.split('').map(function (c, idx) {
          if (idx < iter) return orig[idx];
          if (c === ' ') return ' ';
          return chars[Math.floor(Math.random() * chars.length)];
        }).join('');
        iter += 2;
        if (iter >= orig.length) { gEl.textContent = orig; clearInterval(iv); }
      }, 35);
    }
    setTimeout(doGlitch, 1800);
    setInterval(doGlitch, 7000);
  }
})();
</script>
