---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<Layout
  title="Free ITGC Audit Workbook — 38 Controls, Excel Template | MarcoWeb"
  description="Download the free ITGC Audit Workbook — 38 IT General Controls across access management, change management, operations, and information security. Aligned to SOX, APRA, and ISO 27001."
>
  <Header />

  <main>

    <!-- Hero -->
    <div class="bg-brand-navy text-white py-16">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-block bg-brand-blue text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide mb-6">Free Download</span>
        <h1 class="text-4xl font-extrabold mb-4 leading-tight">ITGC Audit Workbook</h1>
        <p class="text-xl text-gray-300 mb-2">38 IT General Controls · Excel Template · SOX · APRA · ISO 27001</p>
        <p class="text-gray-400 text-sm">Used by IT auditors and GRC professionals across Australia</p>
      </div>
    </div>

    <!-- Main content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-14">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">

        <!-- What's inside -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
          <h2 class="text-xl font-bold text-gray-900 mb-5">What's inside</h2>
          <ul class="space-y-3 text-sm text-gray-600">
            {[
              '38 ITGC controls across 9 domains',
              'Risk and control matrix (RACM) format',
              'Test steps and evidence requirements',
              'Control ratings: Effective / Deficient / N/A',
              'SOX, APRA CPS 234, and ISO 27001 alignment',
              'Access management & IAM controls',
              'Change and patch management',
              'Backup, DR, and physical security',
              'Audit workpaper-ready layout',
            ].map(item => (
              <li class="flex items-start gap-2">
                <span class="text-brand-blue font-bold mt-0.5">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Form -->
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
          <h2 class="text-xl font-bold text-gray-900 mb-2">Get the workbook free</h2>
          <p class="text-sm text-gray-500 mb-6">Enter your email and download instantly. No spam — unsubscribe any time.</p>

          <div id="form-wrap">
            <form id="lead-form" novalidate>
              <div class="mb-4">
                <label for="lead-name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                <input
                  type="text"
                  id="lead-name"
                  name="name"
                  placeholder="Marco Cavani"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-brand-blue"
                />
              </div>
              <div class="mb-5">
                <label for="lead-email" class="block text-sm font-medium text-gray-700 mb-1">Work email <span class="text-red-500">*</span></label>
                <input
                  type="email"
                  id="lead-email"
                  name="email"
                  placeholder="you@company.com"
                  required
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-brand-blue"
                />
              </div>
              <button
                type="submit"
                id="lead-btn"
                class="w-full bg-brand-blue hover:bg-brand-light text-white font-bold py-3 rounded-lg transition-colors text-sm"
              >
                Download Free Workbook →
              </button>
              <p id="lead-error" class="text-red-500 text-xs mt-3" style="display:none"></p>
            </form>
          </div>

          <div id="lead-success" style="display:none" class="text-center py-4">
            <p class="text-2xl mb-2">🎉</p>
            <p class="font-bold text-gray-900 mb-1">Your download is ready!</p>
            <p class="text-sm text-gray-500 mb-4">You're also subscribed to MarcoWeb updates.</p>
            <a id="download-link" href="#" target="_blank" class="inline-block bg-brand-blue hover:bg-brand-light text-white font-bold px-6 py-3 rounded-lg transition-colors text-sm">
              Download Now →
            </a>
          </div>

          <p class="text-xs text-gray-400 mt-4 text-center">No spam. Unsubscribe any time.</p>
        </div>

      </div>

      <!-- Control domains -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-6">38 Controls across 9 domains</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {[
            { domain: 'IT Governance', controls: 'A1–A3' },
            { domain: 'Network & Infrastructure Security', controls: 'B1–B9' },
            { domain: 'Access Management', controls: 'C1–C6' },
            { domain: 'Application Controls', controls: 'DEF series' },
            { domain: 'Change Management', controls: 'G1–G5' },
            { domain: 'Backup & Recovery', controls: 'H1–H2' },
            { domain: 'Physical Security', controls: 'I1–I2' },
            { domain: 'Third-Party Risk', controls: 'A2' },
            { domain: 'IT Risk Management', controls: 'A3' },
          ].map(({ domain, controls }) => (
            <div class="bg-gray-50 rounded-lg px-4 py-3">
              <p class="text-xs font-bold text-brand-blue mb-0.5">{controls}</p>
              <p class="text-sm font-medium text-gray-800">{domain}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="bg-brand-navy text-white rounded-2xl p-8 text-center">
        <h2 class="text-xl font-bold mb-2">Also try the ITGC Assessment Tool</h2>
        <p class="text-gray-300 text-sm mb-5">Browser-based platform for ITGC assessments — generate workpapers and export to Excel.</p>
        <a href="https://marcoweb-itgc-saas.netlify.app" target="_blank" rel="noopener noreferrer"
          class="inline-block bg-brand-blue hover:bg-brand-light text-white font-bold px-6 py-3 rounded-full transition-colors text-sm">
          Try the ITGC Tool ↗
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<script is:inline>
(function () {
  var DOWNLOAD_URL = 'https://lgyblltyytfmoovigdrj.supabase.co/storage/v1/object/public/templates/ITGC_Audit_Workbook.xlsx'

  var form = document.getElementById('lead-form')
  if (!form) return

  form.addEventListener('submit', async function (e) {
    e.preventDefault()
    var email = document.getElementById('lead-email').value.trim()
    var btn = document.getElementById('lead-btn')
    var errorEl = document.getElementById('lead-error')

    if (!email || !email.includes('@')) {
      errorEl.textContent = 'Please enter a valid email address.'
      errorEl.style.display = 'block'
      return
    }

    btn.disabled = true
    btn.textContent = 'Sending…'
    errorEl.style.display = 'none'

    try {
      var res = await fetch('/.netlify/functions/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email }),
      })

      if (res.ok) {
        document.getElementById('form-wrap').style.display = 'none'
        document.getElementById('download-link').href = DOWNLOAD_URL
        document.getElementById('lead-success').style.display = 'block'
      } else {
        throw new Error()
      }
    } catch {
      btn.disabled = false
      btn.textContent = 'Download Free Workbook →'
      errorEl.textContent = 'Something went wrong. Please try again.'
      errorEl.style.display = 'block'
    }
  })
})()
</script>
