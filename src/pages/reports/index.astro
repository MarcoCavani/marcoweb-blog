---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import PostCard from '../../components/PostCard.astro'
import CTABox from '../../components/CTABox.astro'
import { getCollection } from 'astro:content'

const today = new Date()
today.setHours(23, 59, 59, 999)
const reports = (await getCollection('blog'))
  .filter(p => p.data.category === 'Digital Report' && p.data.pubDate <= today)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
---

<Layout
  title="Digital Reports | MarcoWeb"
  description="In-depth cybersecurity and IT governance digital reports by Marco Cavani, available on request."
>
  <Header />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-3">Digital Reports</h1>
      <p class="text-lg text-gray-500 max-w-xl mx-auto">
        In-depth cybersecurity assessments and IT governance analyses. Full reports available on request.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-10">
      {reports.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          slug={post.slug}
          pubDate={post.data.pubDate}
          category={post.data.category}
          readTime={post.data.readTime}
          heroImage={post.data.heroImage}
          tags={post.data.tags}
          basePath="/reports"
        />
      ))}
    </div>

    {reports.length === 0 && (
      <p class="text-center text-gray-400 py-20">No reports yet. Check back soon.</p>
    )}

    <div class="mt-16">
      <CTABox variant="full" />
    </div>
  </main>

  <Footer />
</Layout>
