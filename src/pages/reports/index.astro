---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import PostCard from '../../components/PostCard.astro'
import CTABox from '../../components/CTABox.astro'
import FilterChips from '../../components/FilterChips.astro'
import { getCollection } from 'astro:content'

const today = new Date()
today.setHours(23, 59, 59, 999)
const reports = (await getCollection('blog'))
  .filter(p => p.data.category === 'Digital Report' && p.data.pubDate <= today && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const industries = [...new Set(reports.map(p => p.data.industry).filter(Boolean))].sort()
const counts = Object.fromEntries(
  industries.map(i => [i, reports.filter(p => p.data.industry === i).length])
)
---

<Layout
  title="Threat Reports by Industry | MarcoWeb"
  description="Breach analyses across FinTech, healthcare, telecom, mining, government and critical infrastructure, what failed, and the controls that would have caught it."
>
  <Header />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-3">Threat Reports</h1>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto leading-relaxed">
        Breach analyses drawn from publicly documented incidents, what happened, what failed,
        and the controls that would have caught it. Filter by your sector.
      </p>
    </div>

    <FilterChips
      values={industries}
      counts={counts}
      total={reports.length}
      allLabel="All sectors"
      param="sector"
      gridId="report-grid"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="report-grid">
      {reports.map(post => (
        <div class="filter-item" data-value={post.data.industry || 'Other'}>
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            category={post.data.industry || post.data.category}
            readTime={post.data.readTime}
            heroImage={post.data.heroImage}
            tags={post.data.tags}
            basePath="/reports"
          />
        </div>
      ))}
    </div>

    <p id="report-grid-empty" class="hidden text-center text-gray-400 py-16">
      No reports in that sector yet.
    </p>

    {reports.length === 0 && (
      <p class="text-center text-gray-400 py-20">No reports yet. Check back soon.</p>
    )}

    <div class="mt-16">
      <CTABox variant="full" />
    </div>
  </main>

  <Footer />
</Layout>
