---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<Layout
  title="Page Not Found | MarcoWeb"
  description="The page you're looking for doesn't exist. Head back to the MarcoWeb homepage or browse the latest cybersecurity analysis."
>
  <Header />

  <main class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-7xl font-extrabold text-brand-blue mb-4">404</p>
    <h1 class="text-3xl font-extrabold text-gray-900 mb-3">Page not found</h1>
    <p class="text-lg text-gray-500 mb-10">
      The page you're looking for may have moved or never existed. Let's get you back on track.
    </p>

    <div class="flex flex-wrap justify-center gap-3">
      <a href="/" class="bg-brand-blue hover:bg-brand-navy text-white font-semibold px-6 py-3 rounded-xl transition-colors">
        Back to Home
      </a>
      <a href="/blog" class="bg-white border border-gray-300 hover:border-brand-blue text-gray-800 font-semibold px-6 py-3 rounded-xl transition-colors">
        Browse the Blog
      </a>
      <a href="/reports" class="bg-white border border-gray-300 hover:border-brand-blue text-gray-800 font-semibold px-6 py-3 rounded-xl transition-colors">
        Digital Reports
      </a>
    </div>

    <p class="text-sm text-gray-400 mt-10">
      Looking for something specific? <a href="/contact" class="text-brand-blue hover:underline">Get in touch</a>.
    </p>
  </main>

  <Footer />
</Layout>
