---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<Layout
  title="About — MarcoWeb"
  description="Marco Cavani is a cybersecurity professional and IT governance specialist sharing insights on threat intelligence, digital security, and risk management."
>
  <Header />

  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Profile section -->
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-12">
      <img
        src="/images/marco.jpg"
        alt="Marco Cavani"
        class="w-32 h-32 rounded-full border-4 border-brand-light object-cover shadow-lg flex-shrink-0"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <div class="w-32 h-32 rounded-full bg-brand-blue border-4 border-brand-light items-center justify-center font-bold text-4xl text-white flex-shrink-0 hidden">M</div>
      <div class="text-center sm:text-left">
        <h1 class="text-4xl font-extrabold text-gray-900 mb-1">Marco Cavani</h1>
        <p class="text-brand-blue font-semibold text-lg mb-3">Cybersecurity Professional &amp; IT Governance Specialist</p>
        <p class="text-gray-500 text-sm">Based in Australia · marcoweb.org</p>
      </div>
    </div>

    <!-- Bio -->
    <div class="prose prose-lg max-w-none text-gray-700 mb-12">
      <p>
        Welcome to MarcoWeb — a platform dedicated to making cybersecurity accessible, practical, and actionable for organisations of all sizes.
      </p>
      <p>
        I specialise in IT governance, threat intelligence, and information security risk management. My work covers everything from in-depth digital reports on real-world threat actors to hands-on analysis of the frameworks and standards that protect critical infrastructure.
      </p>
      <p>
        Through this site I publish original research, case studies, and analysis on topics including ransomware campaigns, social engineering attacks, privacy legislation, incident response, and the evolving role of AI in cybersecurity — drawing on sources like the FBI, CISA, ACSC, NIST, and IBM Security.
      </p>
      <p>
        I also built the <a href="https://marcoweb-itgc-saas.netlify.app" target="_blank" rel="noopener noreferrer" class="text-brand-blue hover:underline">ITGC Audit Tool</a> — a free, browser-based platform for IT General Controls assessments used in IT audit and compliance engagements.
      </p>
    </div>

    <!-- What you'll find -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">What You'll Find Here</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex gap-3 items-start">
          <span class="text-brand-blue text-xl mt-0.5">🔐</span>
          <div>
            <p class="font-semibold text-gray-800">Threat Intelligence</p>
            <p class="text-sm text-gray-500">Real-world attack breakdowns — Scattered Spider, ransomware, deepfakes, phishing</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="text-brand-blue text-xl mt-0.5">📋</span>
          <div>
            <p class="font-semibold text-gray-800">Digital Reports</p>
            <p class="text-sm text-gray-500">In-depth security assessments available on request for enterprises and researchers</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="text-brand-blue text-xl mt-0.5">🏛️</span>
          <div>
            <p class="font-semibold text-gray-800">IT Governance</p>
            <p class="text-sm text-gray-500">NIST, PSPF, ISO 27001, Privacy Act — frameworks that matter in practice</p>
          </div>
        </div>
        <div class="flex gap-3 items-start">
          <span class="text-brand-blue text-xl mt-0.5">🛡️</span>
          <div>
            <p class="font-semibold text-gray-800">Incident Response</p>
            <p class="text-sm text-gray-500">Case studies and playbooks drawn from real incidents and NIST guidelines</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact -->
    <div class="bg-brand-navy text-white rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-bold mb-3">Get in Touch</h2>
      <p class="text-gray-300 mb-6">
        For report requests, collaboration enquiries, or general questions — reach out directly.
      </p>
      <a
        href="mailto:cavaniaustralia@gmail.com"
        class="inline-block bg-brand-blue hover:bg-brand-light text-white font-semibold px-8 py-3 rounded-full transition-colors"
      >
        cavaniaustralia@gmail.com
      </a>
    </div>

  </main>

  <Footer />
</Layout>
