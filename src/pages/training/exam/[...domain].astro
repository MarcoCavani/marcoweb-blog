---
import Layout from '../../../layouts/Layout.astro'
import Header from '../../../components/Header.astro'
import Footer from '../../../components/Footer.astro'
import ExamMode from '../../../components/ExamMode.astro'
import { getCollection } from 'astro:content'

// One timed practice exam per domain that has questions. Domain 1 keeps the
// bare /training/exam/ URL it has always had (param undefined); later domains
// live at /training/exam/domain-2/ and so on. A new domain gets an exam the
// moment its lessons carry quizzes, no page edits needed.

const DOMAIN_TITLES: Record<number, string> = {
  1: 'The Information Systems Auditing Process',
  2: 'Governance and Management of IT',
  3: 'IS Acquisition, Development and Implementation',
  4: 'IS Operations and Business Resilience',
  5: 'Protection of Information Assets',
}

export async function getStaticPaths() {
  const all = await getCollection('lessons')
  const paths = []
  for (let n = 1; n <= 5; n++) {
    const lessons = all
      .filter(l => l.data.course === `cisa-domain-${n}`)
      .sort((a, b) => a.data.order - b.data.order)
    const questions = lessons.flatMap(l =>
      (l.data.quiz ?? []).map(q => ({
        ...q,
        // Domain 1 lesson 1 is exam technique, not a domain topic; label it so.
        topic: l.data.title.replace(/^How CISA Questions Are Written$/, 'Exam technique'),
        lessonSlug: l.slug,
        lessonTitle: l.data.title,
      }))
    )
    if (!questions.length) continue
    paths.push({
      // Domain 1 renders at /training/exam/; the rest under /training/exam/domain-N/.
      params: { domain: n === 1 ? undefined : `domain-${n}` },
      props: { n, questions },
    })
  }
  return paths
}

const { n, questions } = Astro.props
const minutes = Math.round((questions.length * 96) / 60)

// Which other domains have an exam, so we can offer a jump between them.
const all = await getCollection('lessons')
const others = [1, 2, 3, 4, 5]
  .map(d => ({
    d,
    count: all.filter(l => l.data.course === `cisa-domain-${d}`)
      .reduce((s, l) => s + (l.data.quiz?.length || 0), 0),
  }))
  .filter(o => o.count > 0)
const examHref = (d: number) => (d === 1 ? '/training/exam/' : `/training/exam/domain-${d}/`)
---

<Layout
  title={`Domain ${n} Practice Exam | CISA Preparation | MarcoWeb`}
  description={`A timed ${questions.length} question practice exam over CISA Domain ${n}, ${DOMAIN_TITLES[n]}. Scored by topic, with full reasoning on every option.`}
>
  <Header />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
    <nav class="text-xs text-gray-400 mb-6">
      <a href="/training" class="hover:text-brand-blue">Training</a>
      <span class="mx-2">›</span>
      <a href={`/training#domain-${n}`} class="hover:text-brand-blue">Domain {n}</a>
      <span class="mx-2">›</span>
      <span class="text-gray-500">Practice exam</span>
    </nav>

    <div class="mb-6">
      <h1 class="text-2xl font-extrabold text-gray-900 leading-tight">Domain {n} practice exam</h1>
      <p class="text-gray-500 mt-1">{DOMAIN_TITLES[n]}</p>
    </div>

    {others.length > 1 && (
      <div class="flex flex-wrap items-center gap-2 mb-8">
        <span class="text-xs uppercase tracking-widest text-gray-400 mr-1">Exams:</span>
        {others.map(o => (
          <a
            href={examHref(o.d)}
            aria-current={o.d === n ? 'page' : undefined}
            class={`text-sm font-semibold rounded-lg px-3 py-1.5 border transition-colors ${
              o.d === n
                ? 'border-brand-blue bg-blue-50 text-brand-blue'
                : 'border-gray-200 text-gray-600 hover:border-brand-blue hover:text-brand-blue'
            }`}
          >
            Domain {o.d}
          </a>
        ))}
      </div>
    )}

    {questions.length > 0 ? (
      <ExamMode questions={questions} id={`exam-cisa-domain-${n}`} />
    ) : (
      <p class="text-gray-500">No questions are available yet.</p>
    )}

    <section class="mt-12 grid sm:grid-cols-2 gap-5">
      <div class="rounded-2xl border border-gray-100 bg-white p-6">
        <h2 class="text-sm font-bold text-gray-900 mb-2">Why there is no feedback until the end</h2>
        <p class="text-sm text-gray-500 leading-relaxed">
          Committing to an answer you cannot check is a skill the exam tests and content study never
          builds. Immediate feedback removes exactly that pressure, so the practice exam withholds it
          and the lesson quizzes provide it instead.
        </p>
      </div>
      <div class="rounded-2xl border border-gray-100 bg-white p-6">
        <h2 class="text-sm font-bold text-gray-900 mb-2">Why {minutes} minutes</h2>
        <p class="text-sm text-gray-500 leading-relaxed">
          The real exam allows 150 questions in 240 minutes, which is 96 seconds each including
          review. This exam holds the same ratio. A generous clock would train the wrong habit.
        </p>
      </div>
    </section>

    <p class="mt-10 text-xs text-gray-400 leading-relaxed">
      Independent training produced by Marco Cavani. Not affiliated with, endorsed by, or sponsored
      by ISACA. CISA is a registered trademark of ISACA. Questions are written for this course and
      are not reproduced from ISACA materials, and no practice result predicts a real exam outcome.
    </p>
  </main>

  <Footer />
</Layout>
