---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import Quiz from '../../components/Quiz.astro'
import LessonVideo from '../../components/LessonVideo.astro'
import TranscriptPlayer from '../../components/TranscriptPlayer.astro'
import CourseSidebar from '../../components/CourseSidebar.astro'
import NewsletterSignup from '../../components/NewsletterSignup.astro'
import { getCollection } from 'astro:content'

// The training videos live in their own YouTube playlist.
// Two playlists, because they are two different things. The CISA course has its
// own so it is findable by anyone searching for exam preparation; "IT Audit
// Training" keeps the older ITGC primer, which is practitioner material rather
// than exam preparation and is no longer part of the course sequence.
const CISA_PLAYLIST = 'PLIiO5GctRcns'
const TRAINING_PLAYLIST = 'PLQVFknVNfL1c'

export async function getStaticPaths() {
  const lessons = await getCollection('lessons')
  return lessons.map(lesson => {
    const siblings = lessons
      .filter(l => l.data.course === lesson.data.course)
      .sort((a, b) => a.data.order - b.data.order)
    const i = siblings.findIndex(l => l.slug === lesson.slug)
    return {
      params: { slug: lesson.slug },
      props: { lesson, siblings, prev: siblings[i - 1], next: siblings[i + 1], position: i + 1, total: siblings.length },
    }
  })
}

const { lesson, siblings, prev, next, position, total } = Astro.props
const { Content } = await lesson.render()

const playlistItems = siblings.map(l => ({
  slug: l.slug,
  title: l.data.title,
  minutes: l.data.minutes,
  hasVideo: !!l.data.videoId,
  questions: l.data.quiz?.length || 0,
}))

// Only offer the YouTube playlist where the course actually has videos. The
// exam-preparation lessons are written first and filmed later, so linking a
// playlist from them would send people to an unrelated course.
const courseHasVideo = siblings.some(l => l.data.videoId)
// The locked-domain panel belongs to the exam course. The older ITGC primer
// lessons are not part of that sequence and should not advertise it.
const isExamCourse = lesson.data.domain !== undefined
const examQuestionCount = siblings.reduce((n, l) => n + (l.data.quiz?.length || 0), 0)
// The exam belongs to the lesson's own domain. Domain 1 keeps the bare URL.
const examUrl = lesson.data.domain === 1
  ? '/training/exam/'
  : `/training/exam/domain-${lesson.data.domain}/`

// Sentence-timed transcript, if one has been generated for this lesson by
// _build/make-transcript.mjs. Eagerly globbed so the lookup is a plain object
// rather than a promise per page.
const transcripts = import.meta.glob('../../data/transcripts/*.json', { eager: true }) as Record<
  string,
  { default: { paragraphs: { t: number; sentences: { t: number; text: string }[] }[] } }
>
const transcript = transcripts[`../../data/transcripts/${lesson.slug}.json`]?.default ?? null
const hasFollowingTranscript = !!(lesson.data.videoId && transcript?.paragraphs?.length)
---

<Layout title={`${lesson.data.title} | IT Audit Training`} description={lesson.data.description}>
  <Header />

  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12" data-current-lesson={lesson.slug}>
    <nav class="text-xs text-gray-400 mb-5">
      <a href="/training" class="hover:text-brand-blue">Training</a>
      <span class="mx-2">›</span>
      <span>{lesson.data.module}</span>
      <span class="mx-2">›</span>
      <span class="text-gray-500">Lesson {position} of {total}</span>
    </nav>

    {/* Everything that orients the learner comes before the video: what the
        lesson is, what it makes them able to do, and the trap it is written
        against. You should know what you are watching for before you press
        play. Constrained to a readable measure rather than the full page width,
        which the player below is free to use. */}
    <div class="max-w-3xl">
      <header class="mb-8">
        <div class="flex flex-wrap items-center gap-3 mb-3">
          <span class="text-xs font-semibold uppercase tracking-widest text-brand-blue bg-blue-50 px-2.5 py-1 rounded-full">
            {lesson.data.module}
          </span>
          <span class="text-xs text-gray-400 tabular-nums">
            {lesson.data.minutes} min{lesson.data.quiz ? ` · ${lesson.data.quiz.length} questions` : ''}
          </span>
          {lesson.data.control && (
            <a href="/blog" class="text-xs text-gray-400 hover:text-brand-blue">Control {lesson.data.control}</a>
          )}
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 leading-tight">{lesson.data.title}</h1>
        <p class="text-lg text-gray-500 mt-4 leading-relaxed">{lesson.data.description}</p>
      </header>

      {(lesson.data.taskStatement || lesson.data.objectives) && (
        <section class="rounded-2xl border border-gray-100 bg-gray-50/70 p-6 mb-6">
          {lesson.data.taskStatement && (
            <>
              <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">
                What this makes you able to do
              </h2>
              <p class="text-gray-700 leading-relaxed mb-5">{lesson.data.taskStatement}</p>
            </>
          )}
          {lesson.data.objectives && lesson.data.objectives.length > 0 && (
            <>
              <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">
                By the end you can
              </h2>
              <ul class="space-y-2">
                {lesson.data.objectives.map(o => (
                  <li class="flex gap-3 text-sm text-gray-600 leading-relaxed">
                    <span class="shrink-0 mt-2 w-1.5 h-1.5 rounded-full bg-brand-blue"></span>
                    <span>{o}</span>
                  </li>
                ))}
              </ul>
            </>
          )}
        </section>
      )}

      {lesson.data.trap && (
        <aside class="rounded-2xl border border-amber-200 bg-amber-50/60 p-6 mb-10">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-amber-700 mb-2">
            The trap
          </h2>
          <p class="text-amber-900 leading-relaxed">{lesson.data.trap}</p>
        </aside>
      )}
    </div>

    {/* The player takes the full page width rather than sharing a row with the
        course outline. Video, transcript and outline together are three columns
        competing for one row, which squeezed the video to about 430px. Outside
        the grid the video gets roughly 700px and the transcript stays wide
        enough to read. The outline follows below, where it still does its job. */}
    {hasFollowingTranscript && (
      <TranscriptPlayer
        videoId={lesson.data.videoId!}
        title={lesson.data.title}
        paragraphs={transcript!.paragraphs}
      />
    )}

    <!-- The outline is docked to the right on desktop and drops below the
         player on smaller screens, where a sticky sidebar would eat the fold. -->
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_20rem] gap-8 lg:gap-10 items-start">
      <div class="min-w-0">
        {!hasFollowingTranscript && lesson.data.videoId && (
          <LessonVideo videoId={lesson.data.videoId} title={lesson.data.title} />
        )}

        {/* The prose body is suppressed once a following transcript exists,
            because the two are the same words twice on one page. The transcript
            is the better of the pair here: it is timed to the narration, it can
            be clicked to seek, and it is what the reader is actually following.
            The markdown still holds the lesson, so removing a video restores it. */}
        {!hasFollowingTranscript && (
          <>
            {lesson.data.videoId && (
              <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4 pt-6 border-t border-gray-100">
                Video transcript
              </h2>
            )}
            <article class="prose prose-lg max-w-none prose-headings:font-bold prose-headings:text-gray-900 prose-a:text-brand-blue prose-strong:text-gray-900">
              <Content />
            </article>
          </>
        )}

        {lesson.data.quiz && lesson.data.quiz.length > 0 && (
          <Quiz questions={lesson.data.quiz} id={`quiz-${lesson.slug}`} />
        )}

        {isExamCourse && (
          <p class="mt-10 text-xs text-gray-400 leading-relaxed">
            Independent training produced by Marco Cavani. Not affiliated with, endorsed by, or
            sponsored by ISACA. CISA is a registered trademark of ISACA. Practice questions are
            written for this course and are not reproduced from ISACA materials.
          </p>
        )}

        <nav
          class="mt-12 pt-8 border-t border-gray-200 flex justify-between gap-4"
          data-lesson-nav
          data-quiz-id={lesson.data.quiz?.length ? `quiz-${lesson.slug}` : undefined}
          data-lesson-slug={lesson.slug}
        >
          {prev ? (
            <a href={`/training/${prev.slug}/`} class="group flex-1 text-left">
              <div class="text-xs text-gray-400 mb-1">← Previous</div>
              <div class="text-sm font-semibold text-gray-700 group-hover:text-brand-blue transition-colors">{prev.data.title}</div>
            </a>
          ) : <div class="flex-1"></div>}
          {next ? (
            <div class="flex-1 text-right min-w-0">
              {/* Locked until the knowledge check is passed. The lock is applied
                  by script on load, so the link still works for anyone without
                  JavaScript rather than becoming a dead end. */}
              <a
                href={`/training/${next.slug}/`}
                data-next-link
                class="group block"
              >
                <div class="text-xs text-gray-400 mb-1" data-next-label>Next →</div>
                <div class="text-sm font-semibold text-gray-700 group-hover:text-brand-blue transition-colors">{next.data.title}</div>
              </a>
              <p class="hidden mt-2 text-xs text-amber-700" data-next-hint>
                Pass the knowledge check above to continue.
              </p>
            </div>
          ) : (
            <div class="flex-1 text-right">
              <div class="text-xs text-gray-400 mb-1">End of module</div>
              <a href="/training" class="text-sm font-semibold text-brand-blue hover:text-brand-navy">Back to the course →</a>
            </div>
          )}
        </nav>
      </div>

      <CourseSidebar
        items={playlistItems}
        currentSlug={lesson.slug}
        module={lesson.data.module}
        playlistUrl={courseHasVideo
          ? `https://www.youtube.com/playlist?list=${isExamCourse ? CISA_PLAYLIST : TRAINING_PLAYLIST}`
          : undefined}
        locked={isExamCourse ? undefined : []}
        lockedHeading={isExamCourse ? 'Remaining domains' : ''}
        examUrl={isExamCourse && examQuestionCount > 0 ? examUrl : undefined}
        examQuestions={isExamCourse ? examQuestionCount : undefined}
      />
    </div>

    <div class="mt-16">
      <NewsletterSignup />
    </div>
  </main>

<script>
  // Gates the Next link on passing the lesson's knowledge check.
  //
  // ⚠️ This is a nudge, not enforcement. The site is static, the next lesson is
  // a public URL, and the pass flag lives in localStorage where anyone can edit
  // it. It exists to stop someone drifting past a check they have not done, not
  // to stop someone determined to skip. Real gating needs server-side state,
  // which means the ITGC tool rather than the blog.
  //
  // The lock is applied by script rather than rendered locked, so a reader
  // without JavaScript gets a working link instead of a dead end.
  const nav = document.querySelector<HTMLElement>('[data-lesson-nav]')
  const quizId = nav?.dataset.quizId
  const slug = nav?.dataset.lessonSlug

  if (nav && quizId && slug) {
    const KEY = `marcoweb:training:passed:${slug}`
    const link = nav.querySelector<HTMLAnchorElement>('[data-next-link]')
    const label = nav.querySelector<HTMLElement>('[data-next-label]')
    const hint = nav.querySelector<HTMLElement>('[data-next-hint]')

    function alreadyPassed() {
      try { return localStorage.getItem(KEY) === '1' } catch { return false }
    }

    function unlock() {
      if (!link || !label || !hint) return
      link.removeAttribute('aria-disabled')
      link.classList.remove('opacity-40', 'pointer-events-none')
      label.textContent = 'Next →'
      hint.classList.add('hidden')
    }

    function lock() {
      if (!link || !label || !hint) return
      link.setAttribute('aria-disabled', 'true')
      link.classList.add('opacity-40', 'pointer-events-none')
      label.textContent = 'Next, locked'
      hint.classList.remove('hidden')
    }

    if (alreadyPassed()) unlock()
    else lock()

    document.addEventListener('quiz:complete', e => {
      const d = (e as CustomEvent).detail
      if (d.id !== quizId) return
      if (!d.passed) return
      try { localStorage.setItem(KEY, '1') } catch { /* private mode, unlock for this visit only */ }
      unlock()
    })
  }
</script>

  <Footer />
</Layout>
