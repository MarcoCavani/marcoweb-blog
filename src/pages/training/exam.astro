---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import ExamMode from '../../components/ExamMode.astro'
import { getCollection } from 'astro:content'

const COURSE = 'cisa-domain-1'

// Every question written across the domain's lessons, in lesson order, each
// tagged with where it came from so the score can route back to the lesson
// behind a weak topic. Questions are NOT shuffled: the order mirrors the
// syllabus, which makes the breakdown legible. Shuffling belongs with a bank
// large enough that the same 36 items are not seen every attempt.
const lessons = (await getCollection('lessons'))
  .filter(l => l.data.course === COURSE)
  .sort((a, b) => a.data.order - b.data.order)

const questions = lessons.flatMap(l =>
  (l.data.quiz ?? []).map(q => ({
    ...q,
    topic: l.data.title.replace(/^How CISA Questions Are Written$/, 'Exam technique'),
    lessonSlug: l.slug,
    lessonTitle: l.data.title,
  }))
)

const minutes = Math.round((questions.length * 96) / 60)
---

<Layout
  title="Domain 1 Practice Exam | CISA Preparation | MarcoWeb"
  description={`A timed ${questions.length} question practice exam over CISA Domain 1, the information systems auditing process. Scored by topic, with full reasoning on every option.`}
>
  <Header />

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
    <nav class="text-xs text-gray-400 mb-6">
      <a href="/training" class="hover:text-brand-blue">Training</a>
      <span class="mx-2">›</span>
      <span class="text-gray-500">Practice exam</span>
    </nav>

    {questions.length > 0 ? (
      <ExamMode questions={questions} id="exam-cisa-domain-1" />
    ) : (
      <p class="text-gray-500">No questions are available yet.</p>
    )}

    <section class="mt-12 grid sm:grid-cols-2 gap-5">
      <div class="rounded-2xl border border-gray-100 bg-white p-6">
        <h2 class="text-sm font-bold text-gray-900 mb-2">Why there is no feedback until the end</h2>
        <p class="text-sm text-gray-500 leading-relaxed">
          Committing to an answer you cannot check is a skill the exam tests and content study never
          builds. Immediate feedback removes exactly that pressure, so the practice exam withholds it
          and the lesson quizzes provide it instead.
        </p>
      </div>
      <div class="rounded-2xl border border-gray-100 bg-white p-6">
        <h2 class="text-sm font-bold text-gray-900 mb-2">Why {minutes} minutes</h2>
        <p class="text-sm text-gray-500 leading-relaxed">
          The real exam allows 150 questions in 240 minutes, which is 96 seconds each including
          review. This exam holds the same ratio. A generous clock would train the wrong habit.
        </p>
      </div>
    </section>

    <p class="mt-10 text-xs text-gray-400 leading-relaxed">
      Independent training produced by Marco Cavani. Not affiliated with, endorsed by, or sponsored
      by ISACA. CISA is a registered trademark of ISACA. Questions are written for this course and
      are not reproduced from ISACA materials, and no practice result predicts a real exam outcome.
    </p>
  </main>

  <Footer />
</Layout>
