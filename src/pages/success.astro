---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<Layout
  title="Subscribed | MarcoWeb"
  description="You're subscribed to MarcoWeb."
>
  <Header />
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <h1 class="text-3xl font-extrabold text-gray-900 mb-4">You're in!</h1>
    <p class="text-gray-500 mb-8">Thanks for subscribing. Watch your inbox for the next report.</p>
    <a href="/" class="inline-block bg-brand-blue hover:bg-brand-light text-white font-semibold px-8 py-3 rounded-full transition-colors">
      Back to Home
    </a>
  </main>
  <Footer />
</Layout>
